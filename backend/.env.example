NODE_ENV=development
PORT=4000
API_VERSION=v1

DATABASE_URL=postgresql://khidmatapp:khidmatapp_password@localhost:5432/khidmatapp?schema=public
TEST_DATABASE_URL=postgresql://khidmatapp_test:khidmatapp_test_password@localhost:5433/khidmatapp_test?schema=public
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=replace_with_access_token_secret
JWT_REFRESH_SECRET=replace_with_refresh_token_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

TWILIO_ACCOUNT_SID=replace_with_twilio_account_sid
TWILIO_AUTH_TOKEN=replace_with_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=replace_with_twilio_verify_service_sid

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=replace_with_aws_access_key_id
AWS_SECRET_ACCESS_KEY=replace_with_aws_secret_access_key
AWS_S3_BUCKET_NAME=replace_with_bucket_name
AWS_S3_PRIVATE_BUCKET=replace_with_private_bucket_name
AWS_S3_PUBLIC_BUCKET=replace_with_public_bucket_name

SENDGRID_API_KEY=replace_with_sendgrid_api_key
EMAIL_FROM=no-reply@khidmatapp.pk

FCM_SERVER_KEY=replace_with_fcm_server_key
FCM_PROJECT_ID=replace_with_fcm_project_id
FCM_CLIENT_EMAIL=replace_with_fcm_client_email
FCM_PRIVATE_KEY=replace_with_fcm_private_key

SENTRY_DSN=replace_with_sentry_dsn
CORS_ORIGIN=http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173
