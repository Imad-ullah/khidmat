generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  phone        String        @unique
  email        String?       @unique
  passwordHash String?
  role         Role          @default(CUSTOMER)
  status       AccountStatus @default(PENDING_VERIFICATION)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  customer      Customer?
  provider      Provider?
  refreshTokens RefreshToken[]
  deviceTokens  DeviceToken[]
  notifications Notification[]
  messages      Message[]
  auditLogs     AuditLog[]     @relation("AdminAuditLogs")

  @@index([phone])
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  @@index([userId])
}

model Customer {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id])
  fullName  String?
  city      String    @default("Mardan")
  address   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  bookings Booking[]
  reviews  Review[]
  disputes Dispute[]
}

model Provider {
  id                 String             @id @default(cuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id])
  displayName        String
  bio                String?
  profilePhotoUrl    String?
  city               String             @default("Mardan")
  address            String?
  cnicNumber         String?
  cnicFrontUrl       String?
  cnicBackUrl        String?
  verificationStatus VerificationStatus @default(PENDING_DOCUMENTS)
  rejectionReason    String?
  onboardingStep     Int                @default(1)
  isAvailable        Boolean            @default(false)
  hasKhidmatBadge    Boolean            @default(false)
  averageRating      Float              @default(0)
  totalReviews       Int                @default(0)
  completedJobs      Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?

  services     ProviderService[]
  bookings     Booking[]
  applications JobApplication[]
  reviews      Review[]
  disputes     Dispute[]

  @@index([verificationStatus])
}

model ServiceCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  iconUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services ProviderService[]
  bookings Booking[]
}

model ProviderService {
  id            String          @id @default(cuid())
  providerId    String
  provider      Provider        @relation(fields: [providerId], references: [id])
  categoryId    String
  category      ServiceCategory @relation(fields: [categoryId], references: [id])
  priceRangeMin Int
  priceRangeMax Int
  description   String?

  @@unique([providerId, categoryId])
  @@index([categoryId])
}

model Booking {
  id                 String        @id @default(cuid())
  customerId         String
  customer           Customer      @relation(fields: [customerId], references: [id])
  providerId         String?
  provider           Provider?     @relation(fields: [providerId], references: [id])
  categoryId         String
  category           ServiceCategory @relation(fields: [categoryId], references: [id])
  bookingType        BookingType
  status             BookingStatus @default(PENDING_CONFIRMATION)
  description        String
  scheduledAt        DateTime?
  completedAt        DateTime?
  closedAt           DateTime?
  totalAmount        Int?
  paymentStatus      PaymentStatus @default(UNPAID)
  paymentMethod      PaymentMethod?
  proofPhotoUrls     String[]
  cancellationReason String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deletedAt          DateTime?

  jobPost      JobPost?
  applications JobApplication[]
  review       Review?
  dispute      Dispute?
  chatRoom     ChatRoom?

  @@index([customerId])
  @@index([providerId])
  @@index([status])
  @@index([categoryId])
}

model JobPost {
  id           String   @id @default(cuid())
  bookingId    String   @unique
  booking      Booking  @relation(fields: [bookingId], references: [id])
  title        String
  budgetMin    Int
  budgetMax    Int
  photoUrls    String[]
  expiresAt    DateTime
  applications JobApplication[]

  @@index([expiresAt])
}

model JobApplication {
  id         String            @id @default(cuid())
  jobPostId  String
  jobPost    JobPost           @relation(fields: [jobPostId], references: [id])
  bookingId  String
  booking    Booking           @relation(fields: [bookingId], references: [id])
  providerId String
  provider   Provider          @relation(fields: [providerId], references: [id])
  quote      Int
  message    String
  status     ApplicationStatus @default(PENDING)
  createdAt  DateTime          @default(now())

  @@unique([jobPostId, providerId])
  @@index([bookingId])
  @@index([providerId])
}

model Review {
  id         String   @id @default(cuid())
  bookingId  String   @unique
  booking    Booking  @relation(fields: [bookingId], references: [id])
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id])
  rating     Int
  comment    String?
  isFlagged  Boolean  @default(false)
  isRemoved  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([customerId])
  @@index([providerId])
}

model Dispute {
  id             String            @id @default(cuid())
  bookingId      String            @unique
  booking        Booking           @relation(fields: [bookingId], references: [id])
  customerId     String
  customer       Customer          @relation(fields: [customerId], references: [id])
  providerId     String?
  provider       Provider?         @relation(fields: [providerId], references: [id])
  status         DisputeStatus     @default(OPEN)
  reason         String
  resolution     DisputeResolution?
  resolutionNote String?
  resolvedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([customerId])
  @@index([providerId])
  @@index([status])
}

model ChatRoom {
  id        String    @id @default(cuid())
  bookingId String    @unique
  booking   Booking   @relation(fields: [bookingId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  messages Message[]
}

model Message {
  id         String      @id @default(cuid())
  chatRoomId String
  chatRoom   ChatRoom    @relation(fields: [chatRoomId], references: [id])
  senderId   String
  sender     User        @relation(fields: [senderId], references: [id])
  type       MessageType
  body       String?
  imageUrl   String?
  createdAt  DateTime    @default(now())

  @@index([chatRoomId, createdAt])
  @@index([senderId])
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id])
  event     NotificationEvent
  title     String
  body      String
  data      Json?
  isRead    Boolean             @default(false)
  createdAt DateTime            @default(now())

  @@index([userId, isRead])
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  platform  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation("AdminAuditLogs", fields: [adminId], references: [id])
  action    String
  targetId  String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([targetId])
}

enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
  SUPER_ADMIN
}

enum AccountStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DELETED
}

enum VerificationStatus {
  PENDING_DOCUMENTS
  PENDING_ADMIN_REVIEW
  VERIFIED
  REJECTED
}

enum BookingType {
  DIRECT
  JOB_POST
}

enum BookingStatus {
  PENDING_CONFIRMATION
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CLOSED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum PaymentMethod {
  CASH
  JAZZCASH
  EASYPAISA
  WALLET
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

enum DisputeResolution {
  REFUND_CUSTOMER
  RELEASE_TO_PROVIDER
  PARTIAL_REFUND
  NO_ACTION
}

enum MessageType {
  TEXT
  IMAGE
}

enum NotificationEvent {
  BOOKING_REQUEST_RECEIVED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  PROVIDER_APPLIED_TO_JOB
  JOB_APPLICATION_ACCEPTED
  JOB_MARKED_COMPLETE
  REVIEW_SUBMITTED
  DISPUTE_FILED
  ACCOUNT_VERIFIED
  ACCOUNT_REJECTED
  KHIDMAT_BADGE_AWARDED
}
